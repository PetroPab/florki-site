{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "importOrder": [
    "^(react|react-dom)(/.*)$",
    "^(next)(/.*)$",
    "<THIRD_PARTY_MODULES>",
    "^@/types(.*)$",
    "^@/lib(.*)$",
    "^@/data(.*)$",
    "^@/components(.*)$",
    "^@/app(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
